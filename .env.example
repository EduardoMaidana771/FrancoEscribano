# Copia este archivo como .env y completa valores actualizados de tu sesion.
# No compartas ni subas .env a git.

DGR_ENDPOINT=https://digital.dgr.gub.uy/DGR_FRONTEND/servlet/com.tramitesenlinea.adgr_6462_dscargarmodelosvehiculo
DGR_REFERER=https://digital.dgr.gub.uy/DGR_FRONTEND/servlet/com.tramitesenlinea.dynformexecutedynformfrontend?6ad31bfb-b163-4717-9652-50117f874938,50,225178,1737227
DGR_DYNFORMKEY=897_1

# Cookie completa en una sola linea:
# GX_CLIENT_ID=...; GX_SESSION_ID=...; ROUTEID=...; JSESSIONID="..."; GxTZOffset=America/Montevideo
DGR_COOKIE=

# Context tal cual del request (JSON en una sola linea)
DGR_CONTEXT={"DFFormInstId":"515159","DFFormId":66,"DFFormVer":1,"DFElemId":1686,"DFElemVer":1,"Mode":"edit"}

# Mantener por defecto en [] salvo que veas otro valor en tu request.
DGR_152_1=[]

# Pegar el valor de 471_1. Puede ser URL-encoded o JSON crudo.
DGR_471_1=
