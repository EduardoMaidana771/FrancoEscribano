    },
    "dgr_minutacargarpersonasprecargaconcatenados": {
      "description": "Build person concatenated string",
      "params": "person fields...",
      "returns": "PF@CI | CI | ... formatted string"
    },
    "dgr_minutacargarpersonasprecargaconcatenadosdsc": {
      "description": "Build person display string",
      "params": "doc_type, ci, nombre, apellido",
