    },
    "dgr_calcularsumresmul": {
      "description": "Calculate sum/subtract/multiply",
      "params": "operation, values...",
      "returns": "result number"
    },
    "dgr_dynformcount": {
      "description": "Count elements in dynamic form grid",
      "params": "grid_ref, mode",
      "returns": "count number"
    },
    "aasignardocumentodesdegam": {
